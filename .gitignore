# =============================================================================
# Nova-Circle — .gitignore
# Covers: Node.js/TypeScript, .NET, Docker, Azure, IDE/editor, OS, secrets
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/
bower_components/

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/
.cache/
.parcel-cache/
*.tsbuildinfo

# .NET build output
bin/
obj/

# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.local
local.settings.json
appsettings.*.json
!appsettings.Development.json.example

# Azure CLI
.azure/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Runtime / temp files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.pid
*.seed
*.pid.lock

# Coverage reports
coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------------------------
# Package manager files
# -----------------------------------------------------------------------------
# npm
package-lock.json.bak

# Yarn
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# pnpm
.pnpm-store/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
test-results/
playwright-report/
.playwright/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore.local

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json.example
.history/

# JetBrains (Rider, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.ncrunchproject

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
\#*\#
.\#*
*.elc

# Sublime Text
*.sublime-workspace

# -----------------------------------------------------------------------------
# Operating system files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
# (tilde backup files are covered in the editor sections above)

# -----------------------------------------------------------------------------
# Certificates and keys
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.pfx
*.p12
*.cer

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.bak
*.orig
*.patch
*.diff

# Client build output
client/dist/

# Generated license reports (uploaded as CI artifacts, not committed)
license-report.json
client/license-report.json
