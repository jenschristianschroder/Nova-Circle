{
  "name": "nova-circle",
  "version": "0.1.0",
  "description": "Privacy-first group calendar – modular monolith backend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"db/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"db/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:api": "vitest run --project api",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "knex migrate:latest --knexfile db/knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile db/knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile db/knexfile.ts",
    "migrate:status": "knex migrate:currentVersion --knexfile db/knexfile.ts",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "knex": "^3.1.0",
    "pg": "^8.13.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
