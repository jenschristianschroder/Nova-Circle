# Nova-Circle – environment variable template
# Copy this file to .env for local development.
# Never commit a .env file with real credentials.

# ── Database ──────────────────────────────────────────────────────────────────
# Azure PostgreSQL Flexible Server.
# In production use a managed-identity connection string; no password required.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nova_circle

# Test database (used by integration and API tests in CI and local dev).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nova_circle_test

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Identity / Auth ───────────────────────────────────────────────────────────
# Azure Entra ID / External ID tenant and audience values.
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_AUTHORITY=https://login.microsoftonline.com/<tenant-id>

# ── Observability ─────────────────────────────────────────────────────────────
# Azure Application Insights connection string.
# Leave empty (or omit) to run without telemetry (default for local dev / tests).
# In production this is injected as a Container App secret at deploy time —
# never hardcode the real value here.
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# Log level: error | warn | info | debug  (default: info)
# LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for cross-origin requests.
# In production set to the frontend domain (e.g. "https://app.novacircle.com").
# When not set, CORS rejects all cross-origin requests (same-origin only).
# CORS_ORIGIN=https://app.novacircle.com
