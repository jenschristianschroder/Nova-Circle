# Nova-Circle – environment variable template
# Copy this file to .env for local development.
# Never commit a .env file with real credentials.

# ── Database ──────────────────────────────────────────────────────────────────
# Azure PostgreSQL Flexible Server.
# In production use a managed-identity connection string; no password required.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nova_circle

# Test database (used by integration and API tests in CI and local dev).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nova_circle_test

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Identity / Auth ───────────────────────────────────────────────────────────
# Azure Entra ID / External ID tenant and audience values.
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
