{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "17473113702902854448"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Deployment location (inherited from main.bicep)"
      }
    },
    "environmentName": {
      "type": "string",
      "metadata": {
        "description": "Short environment name used as a resource-name suffix (e.g. \"dev\")"
      }
    }
  },
  "variables": {
    "registryName": "[format('crnova{0}{1}', parameters('environmentName'), substring(uniqueString(resourceGroup().id), 0, 6))]"
  },
  "resources": [
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('registryName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": false
      }
    }
  ],
  "outputs": {
    "loginServer": {
      "type": "string",
      "metadata": {
        "description": "Container Registry login server (e.g. crnova<env>.azurecr.io)"
      },
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('registryName')), '2023-07-01').loginServer]"
    },
    "resourceId": {
      "type": "string",
      "metadata": {
        "description": "Container Registry resource ID"
      },
      "value": "[resourceId('Microsoft.ContainerRegistry/registries', variables('registryName'))]"
    },
    "name": {
      "type": "string",
      "metadata": {
        "description": "Container Registry resource name"
      },
      "value": "[variables('registryName')]"
    }
  }
}